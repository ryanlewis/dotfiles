#!/bin/bash
# Install command-line tools NOT managed by mise aqua backend
# Most tools are now managed via mise aqua (see private_dot_config/mise/config.toml.tmpl)
# This script only installs tools not available in (or not taken from) the aqua registry:
#   - btop (asset naming issue in aqua registry)
#   - httpie (not in aqua, httpie-go is different)
#   - broot (not in aqua registry)
#   - tldr/tealdeer (tlrc available but different implementation)
#   - pinentry (passphrase prompt for gpg-agent)
#   - tmux + helix (terminal multiplexer / editor; from the OS package manager)
#   - worktrunk, biome, eza (macOS), ktlint (macOS)
#
# Runs in the `after` pass *following* run_onchange_after_03-install-languages so
# that mise-provided node/npm exist for the biome step, and after the cleanup in
# run_onchange_after_04 so freshly-installed binaries are never swept away.
#
# Version hash: {{ include "private_dot_config/mise/config.toml.tmpl" | sha256sum }}
set -e

# Ensure ~/.local/bin and mise shims are in PATH
mkdir -p "$HOME/.local/bin"
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"

echo "🛠️ Installing command-line tools (non-aqua)..."

# Helper function to get architecture
get_arch() {
    local arch=$(uname -m)
    case "$arch" in
        x86_64) echo "x86_64" ;;
        aarch64|arm64) echo "arm64" ;;
        *) echo "$arch" ;;
    esac
}

ARCH=$(get_arch)

# Install btop
if ! command -v btop &> /dev/null; then
    echo "📊 Installing btop..."
    {{ if eq .chezmoi.os "darwin" -}}
    brew install btop
    {{ else if eq .chezmoi.os "linux" -}}
    if command -v apt &> /dev/null; then
        sudo apt-get update -qq && sudo apt-get install -y -qq btop
    elif command -v dnf &> /dev/null; then
        sudo dnf install -y btop
    elif command -v pacman &> /dev/null; then
        sudo pacman -S --noconfirm btop
    else
        # Binary installation fallback
        BTOP_VERSION="1.4.7"
        if [[ "$ARCH" == "x86_64" ]]; then
            BTOP_ARCH="x86_64-linux-musl"
        elif [[ "$ARCH" == "arm64" ]]; then
            BTOP_ARCH="aarch64-linux-musl"
        fi

        if [[ -n "${BTOP_ARCH:-}" ]]; then
            wget -qO /tmp/btop.tbz "https://github.com/aristocratos/btop/releases/download/v${BTOP_VERSION}/btop-${BTOP_ARCH}.tbz"
            tar -xjf /tmp/btop.tbz -C /tmp
            if [[ -f /tmp/btop/bin/btop ]]; then
                mv /tmp/btop/bin/btop "$HOME/.local/bin/"
                chmod +x "$HOME/.local/bin/btop"
                echo "✓ btop installed successfully"
            fi
            rm -rf /tmp/btop.tbz /tmp/btop
        fi
    fi
    {{ end -}}
fi

# Install tldr (tlrc on macOS, tealdeer on Linux)
if ! command -v tldr &> /dev/null; then
    echo "📖 Installing tldr..."
    {{ if eq .chezmoi.os "darwin" -}}
    brew install tlrc
    {{ else if eq .chezmoi.os "linux" -}}
    TLDR_VERSION="3.3.0"
    if [[ "$ARCH" == "x86_64" ]]; then
        TLDR_ARCH="x86_64-unknown-linux-musl"
    elif [[ "$ARCH" == "arm64" ]]; then
        TLDR_ARCH="aarch64-unknown-linux-musl"
    fi

    if [[ -n "${TLDR_ARCH:-}" ]]; then
        # Download tldr binary directly (tealdeer implementation)
        # Fix: Correct filename format for tealdeer releases
        if [[ "$ARCH" == "x86_64" ]]; then
            TLDR_FILE="tealdeer-linux-x86_64-musl"
        elif [[ "$ARCH" == "arm64" ]]; then
            TLDR_FILE="tealdeer-linux-aarch64-musl"
        fi

        if wget -qO "$HOME/.local/bin/tldr" "https://github.com/dbrgn/tealdeer/releases/download/v${TLDR_VERSION}/${TLDR_FILE}" 2>/dev/null; then
            chmod +x "$HOME/.local/bin/tldr"
            echo "✓ tldr installed successfully"
        else
            echo "⚠️  Failed to download tldr, skipping..."
        fi
    fi
    {{ end -}}
fi

# Install httpie
if ! command -v http &> /dev/null; then
    echo "🌐 Installing httpie..."
    {{ if eq .chezmoi.os "darwin" -}}
    brew install httpie
    {{ else if eq .chezmoi.os "linux" -}}
    if command -v apt &> /dev/null; then
        sudo apt-get update -qq && sudo apt-get install -y -qq httpie
    elif command -v dnf &> /dev/null; then
        sudo dnf install -y httpie
    elif command -v pacman &> /dev/null; then
        sudo pacman -S --noconfirm httpie
    fi
    {{ end -}}
fi

# Install broot
if ! command -v broot &> /dev/null; then
    echo "🌳 Installing broot..."
    {{ if eq .chezmoi.os "darwin" -}}
    brew install broot
    {{ else if eq .chezmoi.os "linux" -}}
    BROOT_VERSION="1.57.0"
    if [[ "$ARCH" == "x86_64" ]]; then
        BROOT_ARCH="x86_64-unknown-linux-musl"
    elif [[ "$ARCH" == "arm64" ]]; then
        BROOT_ARCH="aarch64-unknown-linux-musl"
    fi

    if [[ -n "${BROOT_ARCH:-}" ]]; then
        wget -qO /tmp/broot.zip "https://github.com/Canop/broot/releases/download/v${BROOT_VERSION}/broot_${BROOT_VERSION}.zip" 2>/dev/null || \
        wget -qO /tmp/broot.zip "https://github.com/Canop/broot/releases/download/v${BROOT_VERSION}/broot-v${BROOT_VERSION}-${BROOT_ARCH}.zip" 2>/dev/null

        if [[ -f /tmp/broot.zip ]]; then
            unzip -qo /tmp/broot.zip -d /tmp 2>/dev/null || true
            # Try to find the broot binary
            if [[ -f "/tmp/${BROOT_ARCH}/broot" ]]; then
                mv "/tmp/${BROOT_ARCH}/broot" "$HOME/.local/bin/"
                chmod +x "$HOME/.local/bin/broot"
                echo "✓ broot installed successfully"
            elif [[ -f "/tmp/broot" ]]; then
                mv "/tmp/broot" "$HOME/.local/bin/"
                chmod +x "$HOME/.local/bin/broot"
                echo "✓ broot installed successfully"
            else
                # Try downloading as tar.gz instead
                wget -qO /tmp/broot.tar.gz "https://github.com/Canop/broot/releases/download/v${BROOT_VERSION}/broot-${BROOT_ARCH}.tar.gz" 2>/dev/null
                if tar -xzf /tmp/broot.tar.gz -C /tmp 2>/dev/null; then
                    if [[ -f "/tmp/broot" ]]; then
                        mv "/tmp/broot" "$HOME/.local/bin/"
                        chmod +x "$HOME/.local/bin/broot"
                        echo "✓ broot installed successfully"
                    else
                        echo "⚠️  Failed to extract broot, skipping..."
                    fi
                    rm -f /tmp/broot.tar.gz
                else
                    echo "⚠️  Failed to download broot, skipping..."
                fi
            fi
            rm -rf /tmp/broot.zip /tmp/${BROOT_ARCH} 2>/dev/null || true
        else
            echo "⚠️  Failed to download broot, skipping..."
        fi
    fi
    {{ end -}}
fi

# Install pinentry (passphrase prompt for gpg-agent)
{{ if eq .chezmoi.os "darwin" -}}
if ! command -v pinentry-mac &> /dev/null; then
    echo "🔐 Installing pinentry-mac..."
    brew install pinentry-mac
fi
{{ else if eq .chezmoi.os "linux" -}}
if ! command -v pinentry &> /dev/null; then
    echo "🔐 Installing pinentry..."
    if command -v apt &> /dev/null; then
        sudo apt-get update -qq && sudo apt-get install -y -qq pinentry-curses
    elif command -v dnf &> /dev/null; then
        sudo dnf install -y pinentry
    elif command -v pacman &> /dev/null; then
        sudo pacman -S --noconfirm pinentry
    fi
fi
{{ end -}}

# Install tmux (terminal multiplexer; drives ta/ca/cn/dogpound and the MOTD tips)
if ! command -v tmux &> /dev/null; then
    echo "🖥️  Installing tmux..."
    {{ if eq .chezmoi.os "darwin" -}}
    brew install tmux
    {{ else if eq .chezmoi.os "linux" -}}
    if command -v apt &> /dev/null; then
        sudo apt-get update -qq && sudo apt-get install -y -qq tmux
    elif command -v dnf &> /dev/null; then
        sudo dnf install -y tmux
    elif command -v pacman &> /dev/null; then
        sudo pacman -S --noconfirm tmux
    fi
    {{ end -}}
fi

# Install helix (modal editor; $EDITOR resolves to hx when present)
if ! command -v hx &> /dev/null; then
    echo "✏️  Installing helix..."
    {{ if eq .chezmoi.os "darwin" -}}
    brew install helix
    {{ else if eq .chezmoi.os "linux" -}}
    if command -v apt &> /dev/null; then
        # helix is absent from older Ubuntu base repos (e.g. 24.04); pull in the
        # maintained PPA when the package isn't already available, then install.
        if ! apt-cache show helix &> /dev/null; then
            sudo add-apt-repository -y ppa:maveonair/helix-editor 2>/dev/null || true
            sudo apt-get update -qq || true
        fi
        sudo apt-get install -y -qq helix || echo "⚠️  helix unavailable via apt, skipping"
    elif command -v dnf &> /dev/null; then
        sudo dnf install -y helix
    elif command -v pacman &> /dev/null; then
        sudo pacman -S --noconfirm helix
    fi
    {{ end -}}
fi

# Install worktrunk (git worktree manager)
# macOS: Homebrew. Linux: cargo (no upstream Homebrew bottle we want to rely on;
# CI runners ship rust, a fresh Linux box needs rustup first — non-fatal if absent).
{{ if eq .chezmoi.os "darwin" -}}
# Migrate any old cargo-installed copy over to Homebrew.
if command -v cargo &> /dev/null && cargo install --list 2>/dev/null | grep -q '^worktrunk '; then
    echo "🌳 Removing cargo-installed worktrunk (migrating to Homebrew)..."
    cargo uninstall worktrunk || true
fi
if ! brew list worktrunk &> /dev/null; then
    echo "🌳 Installing worktrunk via Homebrew..."
    brew install worktrunk
    # Set up shell integration (wrapper function + completions)
    command -v wt &> /dev/null && wt config shell install -y
fi
{{ else if eq .chezmoi.os "linux" -}}
if ! command -v wt &> /dev/null; then
    echo "🌳 Installing worktrunk..."
    if command -v cargo &> /dev/null; then
        # worktrunk's MSRV moves with the toolchain; keep stable current first.
        command -v rustup &> /dev/null && rustup update stable
        cargo install worktrunk
        # Set up shell integration (wrapper function + completions)
        command -v wt &> /dev/null && wt config shell install -y
    else
        echo "⚠️  cargo not found, skipping worktrunk installation"
    fi
fi
{{ end -}}

# Install biome (via npm; node/npm come from mise, hence the after-languages order)
if ! command -v biome &> /dev/null; then
    echo "🧹 Installing biome..."
    if command -v npm &> /dev/null; then
        npm install --global @biomejs/biome
        # npm globals under mise-managed node aren't on $PATH until reshimmed;
        # generate the shim so `biome` resolves via ~/.local/share/mise/shims.
        command -v mise &> /dev/null && mise reshim 2>/dev/null || true
    else
        echo "⚠️  npm not found, skipping biome installation. Install Node.js first."
    fi
fi

# Install eza (macOS only - Linux uses mise aqua)
{{ if eq .chezmoi.os "darwin" -}}
if ! command -v eza &> /dev/null; then
    echo "🦎 Installing eza..."
    brew install eza
fi
{{ end -}}

# Install ktlint (macOS only)
{{ if eq .chezmoi.os "darwin" -}}
if ! command -v ktlint &> /dev/null; then
    echo "🅺 Installing ktlint..."
    brew install ktlint
fi
{{ end -}}

echo "✓ All non-aqua tools installed/updated successfully"
