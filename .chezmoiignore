# Files to ignore based on OS
{{ if ne .chezmoi.os "darwin" }}
.config/fish/conf.d/macos.fish
{{ end }}

# Per-host ignores: managed gitconfig drifts here (gh credential helper writes)
{{ if and .isWork (eq .chezmoi.hostname .workHostname) }}
.gitconfig
{{ end }}

# macOS launcher scripts (Tuna -> ~/Library/Scripts, Raycast -> ~/dev/raycast-scripts).
# Gate by OS and by app install. Off-darwin: suppress whole trees (no stray ~/Library
# on Linux VMs). On darwin: deploy each set only when its app bundle is present.
{{ if ne .chezmoi.os "darwin" }}
Library/**
dev/raycast-scripts/**
{{ else }}
{{ if not (stat "/Applications/Tuna.app") }}
Library/Scripts
{{ end }}
{{ if not (stat "/Applications/Raycast.app") }}
dev/raycast-scripts
{{ end }}
{{ end }}

# Always ignore
README.md
CLAUDE.md
LICENSE
.DS_Store
*.swp
*~
.git
.gitignore

# Repo-meta files (not meant to be deployed to home dir)
install.sh
Dockerfile
docker-test.sh
test.sh
setup-aliases.sh
SCRIPTS.md
renovate.json
test-chezmoi-data.yaml