# Ghostty Terminal Configuration

# ── Theme ────────────────────────────────────────────────────
# Auto light/dark switching that follows the macOS system appearance.
# Dark mode uses the built-in Ayu; light mode uses the built-in Catppuccin Latte.
# Run `ghostty +list-themes` to browse alternatives.
theme = light:Catppuccin Latte,dark:Ayu

# ── Font ─────────────────────────────────────────────────────
#font-family = IosevkaNerdFont
#font-family = "IoskeleyMono Nerd Font"
font-family = "Maple Mono NF"
font-size = 14
# Faux-bold the strokes a touch (macOS); helps text read heavier on light backgrounds.
font-thicken = true
font-feature = +liga
font-feature = +calt

# ── Window & Appearance ──────────────────────────────────────
#macos-titlebar-style = hidden
macos-titlebar-style = transparent
macos-window-buttons = hidden
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
# Both modes run fully opaque (no background-opacity set). background-blur-radius
# only takes effect if you reintroduce transparency.
background-blur-radius = 10
window-save-state = always
macos-window-shadow = true
# Dim unfocused splits so the active pane pops. The fill defaults to the
# theme background, so dimming adapts to light/dark mode automatically.
unfocused-split-opacity = 0.75
# Mid-grey split borders, legible against both light and dark backgrounds
split-divider-color = #555555


# ── Shell ────────────────────────────────────────────────────
# Explicit zsh path; remove if zsh is your login shell
command = /bin/zsh
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# ── Cursor ───────────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 2

# ── Global Hotkeys ───────────────────────────────────────────
# Show/hide all Ghostty windows from anywhere (works even when unfocused)
keybind = global:alt+space=toggle_visibility

# ── Quick Terminal (hotkey window) ───────────────────────────
# keybind = global:§=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.15
quick-terminal-autohide = true

# ── Split Panes ─────────────────────────────────────────────
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Navigate splits
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom

# Resize splits
keybind = cmd+ctrl+left=resize_split:left,20
keybind = cmd+ctrl+right=resize_split:right,20
keybind = cmd+ctrl+up=resize_split:up,20
keybind = cmd+ctrl+down=resize_split:down,20

# Zoom/unzoom current split (like tmux prefix+z)
keybind = cmd+shift+enter=toggle_split_zoom

# Equalise splits
keybind = cmd+shift+e=equalize_splits

# ── Prompt Navigation (requires shell integration) ──────────
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

# ── Tabs ─────────────────────────────────────────────────────
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab

# ── Clipboard ────────────────────────────────────────────────
copy-on-select = clipboard
clipboard-paste-protection = true

# ── Scrollback ───────────────────────────────────────────────
scrollback-limit = 100000

# ── tmux shortcuts (Alt+Shift → panes/windows) ──────────────────
# Window access (1-9)
keybind = alt+shift+1=text:\x1b!
keybind = alt+shift+2=text:\x1b@
keybind = alt+shift+3=text:\x1b#
keybind = alt+shift+4=text:\x1b$
keybind = alt+shift+5=text:\x1b%
keybind = alt+shift+6=text:\x1b^
keybind = alt+shift+7=text:\x1b&
keybind = alt+shift+8=text:\x1b*
keybind = alt+shift+9=text:\x1b(
# Pane navigation (hjkl)
keybind = alt+shift+h=text:\x1bH
keybind = alt+shift+j=text:\x1bJ
keybind = alt+shift+k=text:\x1bK
keybind = alt+shift+l=text:\x1bL
# Window navigation ([ / ])
keybind = alt+shift+left_bracket=text:\x1b{
keybind = alt+shift+right_bracket=text:\x1b}

# ── Claude Code (Shift+Enter for newline in tmux) ────────────
keybind = shift+enter=text:\x1b\r

# ── Modifier Keys ────────────────────────────────────────────
# Right Option sends Alt/ESC sequences (tmux, readline, alt+shift+* binds)
# Left Option stays as macOS compose key (ø, å, accents)
macos-option-as-alt = right

# ── Misc ─────────────────────────────────────────────────────
#keybind = cmd+q=unbind
confirm-close-surface = true
mouse-hide-while-typing = true
auto-update = check
focus-follows-mouse = false
