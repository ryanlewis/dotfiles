# Ghostty Terminal Configuration

# ── Theme ────────────────────────────────────────────────────
# Auto light/dark switching based on macOS appearance
# Run `ghostty +list-themes` to browse alternatives
#theme = light:Catppuccin Latte,dark:Ayu
theme = Ayu

# ── Font ─────────────────────────────────────────────────────
font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true
font-feature = +liga
font-feature = +calt

# ── Window & Appearance ──────────────────────────────────────
#macos-titlebar-style = hidden
macos-titlebar-style = transparent
macos-window-buttons = hidden
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
background-opacity = 0.95
background-blur-radius = 10
window-save-state = always
macos-window-shadow = true
# Dim unfocused splits with a pure black fill so the active pane pops
unfocused-split-opacity = 0.75
unfocused-split-fill = #000000
# Lighter split borders (visible against dark backgrounds)
split-divider-color = #555555


# ── Shell ────────────────────────────────────────────────────
# Explicit fish path; remove if fish is your login shell
command = /opt/homebrew/bin/fish
shell-integration = fish
shell-integration-features = cursor,sudo,title

# ── Cursor ───────────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 2

# ── Quick Terminal (hotkey window) ───────────────────────────
# keybind = global:§=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.15
quick-terminal-autohide = true

# ── Split Panes ─────────────────────────────────────────────
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Navigate splits
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom

# Resize splits
keybind = cmd+ctrl+left=resize_split:left,20
keybind = cmd+ctrl+right=resize_split:right,20
keybind = cmd+ctrl+up=resize_split:up,20
keybind = cmd+ctrl+down=resize_split:down,20

# Zoom/unzoom current split (like tmux prefix+z)
keybind = cmd+shift+enter=toggle_split_zoom

# Equalise splits
keybind = cmd+shift+e=equalize_splits

# ── Prompt Navigation (requires shell integration) ──────────
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

# ── Tabs ─────────────────────────────────────────────────────
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab

# ── Clipboard ────────────────────────────────────────────────
copy-on-select = clipboard
clipboard-paste-protection = true

# ── Scrollback ───────────────────────────────────────────────
scrollback-limit = 100000

# ── tmux shortcuts (Alt+Shift → panes/windows) ──────────────────
# Window access (1-9)
keybind = alt+shift+1=text:\x1b!
keybind = alt+shift+2=text:\x1b@
keybind = alt+shift+3=text:\x1b#
keybind = alt+shift+4=text:\x1b$
keybind = alt+shift+5=text:\x1b%
keybind = alt+shift+6=text:\x1b^
keybind = alt+shift+7=text:\x1b&
keybind = alt+shift+8=text:\x1b*
keybind = alt+shift+9=text:\x1b(
# Pane navigation (hjkl)
keybind = alt+shift+h=text:\x1bH
keybind = alt+shift+j=text:\x1bJ
keybind = alt+shift+k=text:\x1bK
keybind = alt+shift+l=text:\x1bL
# Window navigation ([ / ])
keybind = alt+shift+left_bracket=text:\x1b{
keybind = alt+shift+right_bracket=text:\x1b}

# ── Claude Code (Shift+Enter for newline in tmux) ────────────
keybind = shift+enter=text:\x1b\r

# ── Modifier Keys ────────────────────────────────────────────
# Right Option sends Alt/ESC sequences (tmux, readline, alt+shift+* binds)
# Left Option stays as macOS compose key (ø, å, accents)
macos-option-as-alt = right

# ── Misc ─────────────────────────────────────────────────────
#keybind = cmd+q=unbind
confirm-close-surface = true
mouse-hide-while-typing = true
auto-update = check
focus-follows-mouse = true
