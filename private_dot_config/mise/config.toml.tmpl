# Global mise configuration
# https://mise.jdx.dev/configuration.html
# Updated: April 2026

[tools]
# Language runtimes
node = "24.14.1" # LTS (Active LTS until April 2028)
python = "miniconda3-latest" # Pre-compiled Python via Miniconda
# renovate: datasource=github-tags depName=golang/go
go = "1.26.1" # Latest stable
# renovate: datasource=github-releases depName=oven-sh/bun
bun = "1.3.11" # Latest stable
java = "temurin-21.0.10+7.0.LTS" # Eclipse Temurin 21 LTS

# CLI tools via aqua backend (pre-built cross-platform binaries)
# https://mise.jdx.dev/dev-tools/backends/aqua.html
"aqua:junegunn/fzf" = "latest"
"aqua:sharkdp/bat" = "latest"
"aqua:sharkdp/fd" = "latest"
{{ if ne .chezmoi.os "darwin" -}}
"aqua:eza-community/eza" = "latest" # Linux only; macOS uses Homebrew
{{ end -}}
"aqua:BurntSushi/ripgrep" = "latest"
"aqua:ajeetdsouza/zoxide" = "latest"
"aqua:muesli/duf" = "latest"
"aqua:bootandy/dust" = "latest"
"aqua:starship/starship" = "latest"
"aqua:atuinsh/atuin" = "latest"
"aqua:dandavison/delta" = "latest"
"aqua:jesseduffield/lazygit" = "latest"
"aqua:cli/cli" = "latest" # GitHub CLI (gh)
"aqua:casey/just" = "latest"
"aqua:charmbracelet/gum" = "latest"
"aqua:direnv/direnv" = "latest"
"aqua:jqlang/jq" = "latest"
"aqua:kubernetes/kubernetes/kubectl" = "latest"
"aqua:ahmetb/kubectx" = "latest"
"aqua:ahmetb/kubectx/kubens" = "latest"
"aqua:astral-sh/uv" = "latest"
"aqua:common-fate/granted" = "0.38.0" # pinned: v0.39.0 missing from releases.commonfate.io
"aqua:neovim/neovim" = "latest" # nvim — modal editor
"aqua:tree-sitter/tree-sitter" = "latest" # nvim-treesitter (main branch) parser compiler
television = "latest" # TUI fuzzy finder (tv)

# CLI tools via npm backend (not in the aqua registry)
# https://mise.jdx.dev/dev-tools/backends/npm.html
"npm:hunkdiff" = "latest" # `hunk` — diff viewer/pager
"npm:cf" = "latest" # Cloudflare CLI

[settings]
# No lockfile: mise.lock is shared with machine-local tools (conf.d/local.toml),
# so a managed/committed lock perpetually drifts against what mise writes here.
# The versions that matter are pinned above; everything else tracks latest.
lockfile = false

# Machine-local tools (e.g. codex, salesforce sf) live in
# ~/.config/mise/conf.d/local.toml — kept out of this repo on purpose.
